# ============================================================
# KONFIGURASI LINGKUNGAN
# ============================================================
# Salin file ini menjadi '.env' dan isi nilai-nilai di bawah ini.
# File .env sudah masuk .gitignore jadi AMAN tidak akan ter-push ke GitHub.
#
# Cara: rename file ini menjadi .env, lalu edit nilainya.
# ============================================================

# Token API Fonnte (WAJIB diisi)
# Dapatkan token dari https://md.fonnte.com/ (login -> ambil token)
FONNTE_TOKEN=isikan_token_fonnte_anda_disini

